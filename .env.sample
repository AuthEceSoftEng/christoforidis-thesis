ARIADNE_API_KEY=""
ARIADNE_BASE_URL=""
ARIADNE_MODEL_ID=""
ARIADNE_PROVIDER=""

# Base directory for output files (results_process.py, filter_results.py)
# Defaults to current working directory if not set
OUTPUT_DIR=""

# Directory containing CVE evaluation JSON files (duplicate_repos.py)
# Defaults to current working directory if not set
EVALUATION_CVES_DIR=""

# SentenceTransformer model used for ChromaDB embeddings (vector_db, query_generator)
# nomic-ai/nomic-embed-text-v1.5 → best retrieval quality, 8192-token window, ~550MB RAM
# BAAI/bge-m3                    → strong retrieval, 8192-token window, ~1.1GB RAM (fp16), no prefix needed
# BAAI/bge-base-en-v1.5          → previous default, 512-token window, ~600MB RAM
EMBEDDING_MODEL="nomic-ai/nomic-embed-text-v1.5"

# Device to run the embedding model on (cpu, cuda, mps, ...)
EMBEDDING_DEVICE="cpu"
CODEQL_RAM=10240
CODEQL_DISK_CACHE=4096
